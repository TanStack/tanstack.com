{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-com",
  "account_id": "8da95258a9c70b54c3e2b374a0079106",
  "main": "src/server.ts",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "limits": {
    "cpu_ms": 300000,
  },
  "triggers": {
    "crons": ["0 9 * * *", "0 */6 * * *", "*/15 * * * *"],
  },
  "assets": {
    "binding": "ASSETS",
  },
  "vars": {
    "SITE_URL": "https://tanstack.com",
  },
  "env": {
    "staging": {
      "name": "tanstack-com-staging",
      "vars": {
        "SITE_URL": "https://tanstack-com-staging.thetanstack.workers.dev",
      },
    },
  },
}
